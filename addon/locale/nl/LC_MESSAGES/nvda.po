#. Translators: Label for the text field where the user enters the name of a formatting attribute.
#: addon\globalPlugins\Attribra.py:133
msgid "Attribute name"
msgstr "Attribuut naam"

#: addon\globalPlugins\Attribra.py:138
msgid "Value (0 = off, 1 = on)"
msgstr "Waarde (0 = uit, 1 = aan)"

#. Translators: Title of the dialog containing the Attribra settings.
#: addon\globalPlugins\Attribra.py:163
msgid "Textattribute settings."
msgstr "Attribuutinstellingen..."

#. Translators: Label for the list of application-specific configuration sections in Attribra settings.
#: addon\globalPlugins\Attribra.py:178
msgid "Section / Application"
msgstr "Sectie / Applicatie"

#. Translators: Button label in Attribra settings to add an application-specific section.
#: addon\globalPlugins\Attribra.py:183
msgid "Add application…"
msgstr "Applicatie toevoegen..."

#. Translators: Button label in Attribra settings to delete an application-specific section.
#: addon\globalPlugins\Attribra.py:185
msgid "Delete application"
msgstr "Applicatie verwijderen..."

#. Translators: Label for the group of standard text attributes that can be marked on a braille display.
#: addon\globalPlugins\Attribra.py:193
msgid "Text attributes"
msgstr "Lettertypeattributen"

#. Translators: Checkbox label for marking bold text on a braille display.
#: addon\globalPlugins\Attribra.py:198
msgid "Bold"
msgstr "Vet"

#. Translators: Checkbox label for marking underlined text on a braille display.
#: addon\globalPlugins\Attribra.py:201
msgid "Underline"
msgstr "Onderstreept"

#. Translators: Checkbox label for marking italic text on a braille display.
#: addon\globalPlugins\Attribra.py:204
msgid "Italic"
msgstr "Cursief"

#. Translators: Checkbox label for marking spelling errors on a braille display.
#: addon\globalPlugins\Attribra.py:207
msgid "Spelling errors"
msgstr "Spelfouten"

#. Translators: Label for advanced Attribra rules not represented by the standard checkboxes.
#: addon\globalPlugins\Attribra.py:219
msgid "Advanced rules"
msgstr "Geavanceerde regels"

#. Translators: Button label in Attribra settings to add an advanced rule.
#: addon\globalPlugins\Attribra.py:224
msgid "Add…"
msgstr "Toevoegen…"

#. Translators: Button label in Attribra settings to edit the selected advanced rule.
#: addon\globalPlugins\Attribra.py:226
msgid "Edit…"
msgstr "Bewerken…"

#. Translators: Button label in Attribra settings to delete the selected advanced rule.
#: addon\globalPlugins\Attribra.py:228
msgid "Delete"
msgstr "Verwijderen…"

#. Translators: Button label in Attribra settings to reload all settings from disk.
#: addon\globalPlugins\Attribra.py:230
msgid "Reload"
msgstr "Herladen"

#. Translators: Prompt for entering an application section name. Examples are executable base names.
#: addon\globalPlugins\Attribra.py:271
msgid "Enter the application/section name (e.g. 'winword' or 'firefox')."
msgstr "Geef de applicatie/sectie naam (b.v. 'winword' of 'firefox')."

#. Translators: Title of the dialog to add an application section.
#: addon\globalPlugins\Attribra.py:273
msgid "Add application"
msgstr "Applicatie toevoegen"

#. Translators: Message spoken when the user did not provide a required application name.
#: addon\globalPlugins\Attribra.py:282
msgid "Missing name."
msgstr "Naam ontbreekt. "

#. Translators: Message spoken when the application section already exists.
#: addon\globalPlugins\Attribra.py:290
msgid "This application already exists."
msgstr "Deze applicatie bestaat al. "

#. Translators: Confirmation message shown before deleting an application section. {name} is the section name.
#: addon\globalPlugins\Attribra.py:301
msgid ""
"Are you sure you want to delete the application/section '{name}'? All rules "
"in this section will be removed."
msgstr ""
"Weet je zeker dat je de applicatie/sectie '[name]'wil verwijderen? Alle "
"regels in deze sectie \n"
"zullen worden verwijdert."

#. Translators: Title of the confirmation dialog.
#: addon\globalPlugins\Attribra.py:303
msgid "Confirm"
msgstr "Bevestigen"

#. Translators: Message spoken after deleting an application section.
#: addon\globalPlugins\Attribra.py:310
msgid "Application deleted."
msgstr "Applicatie verwijdert. "

#. Translators: Title of the dialog to add an advanced rule.
#: addon\globalPlugins\Attribra.py:376
msgid "Add rule"
msgstr "Regel toevoegen"

#. Translators: Message spoken when the attribute name field is empty.
#: addon\globalPlugins\Attribra.py:382 addon\globalPlugins\Attribra.py:403
msgid "Missing attribute name."
msgstr "Attribuutnaam ontbreekt. "

#. Translators: Title of the dialog to edit an advanced rule.
#: addon\globalPlugins\Attribra.py:397
msgid "Edit rule"
msgstr "regel bewerken"

#. Translators: Message spoken after reloading Attribra settings from disk.
#: addon\globalPlugins\Attribra.py:427
msgid "Attribra settings reloaded."
msgstr "Attribra instellingen zijn herladen. "

#. Translators: Message spoken after saving Attribra settings.
#: addon\globalPlugins\Attribra.py:441
msgid "Attribra settings saved."
msgstr "Attribra instellingen opgeslagen. "

#. Translators: Message spoken when saving Attribra settings failed.
#: addon\globalPlugins\Attribra.py:445
msgid "Save failed; see log for details."
msgstr "Opslaan mislukt, zie de log voor details. "

#. Translators: Label for a button in NVDA's Braille settings that opens the Attribra configuration dialog.
#: addon\globalPlugins\Attribra.py:495
msgid "Textattribute settings…"
msgstr "Attribuutinstellingen..."

#. Translators: Message spoken when the Attribra settings dialog could not be opened.
#: addon\globalPlugins\Attribra.py:528
msgid "Could not open Attribra settings."
msgstr "Kon attribuutinstellingen niet openen. "

#. Translators: Message spoken when toggling debug logging of TextInfo at the cursor. {state} is "start" or "stop".
#. Translators: The state toggled by the "log fields at cursor" command.
#: addon\globalPlugins\Attribra.py:654
msgid "start"
msgstr "start"

#: addon\globalPlugins\Attribra.py:654
msgid "stop"
msgstr "stop"

#: addon\globalPlugins\Attribra.py:655
msgid "Debug TextInfo logging: {state}"
msgstr "Debug TextInfo logging: {state}"

#: addon\globalPlugins\BrailleSelection.py:74
msgid "Braille selection marking: enabled"
msgstr "Selectiemarkering in braille ingeschakeld. "

#. Translators: Message reported when braille selection marking has been disabled.
#: addon\globalPlugins\BrailleSelection.py:77
msgid "Braille selection marking: disabled"
msgstr "Selectiemarkering in braille uitgeschakeld. "

#. Translators: Label for a checkbox in NVDA's Braille settings panel.
#. Translators: When enabled, dots 7 and 8 are added to the braille cells corresponding to the selected item's text.
#: addon\globalPlugins\BrailleSelection.py:106
msgid "Mark selected items with dots 7 and 8 (item text only)"
msgstr "Markeert geselecteerde items met punten 7 en 8 (alleen itemtekst)"

#. Translators: Description for an input gesture/script.
#. Translators: This script toggles marking of selected items in braille using dots 7 and 8.
#: addon\globalPlugins\BrailleSelection.py:150
msgid "Toggles braille selection marking with dots 7 and 8 on or off."
msgstr "Schakelt de selectiemarkering met punten 7 en 8 aan of uit."

#. Translators: Script category in the Input Gestures dialog.
#: addon\globalPlugins\BrailleSelection.py:152
msgid "Braille"
msgstr "Braille"

#. Add-on summary/title, usually the user visible name of the add-on
#. Translators: Summary/title for this add-on
#. to be shown on installation and add-on information found in add-on store
#: buildVars.py:21
msgid "braille Plus"
msgstr "braille Plus"

#. Add-on description
#. Translators: Long description to be shown for this add-on on add-on information from add-on store
#: buildVars.py:24
msgid ""
"Displays the selection of items in braille with dots 7 and 8, as well as "
"formatting thanks to Attribra."
msgstr ""
"Toont de selectie van items in braille met punten 7 en 8, alsmede opmaak "
"dankzij Attribra. "

#. Brief changelog for this version
#. Translators: what's new content for the add-on version to be shown in the add-on store
#: buildVars.py:29
msgid ""
" This release adds a new, much more simple to use interface to configure "
"text attributes. \n"
"    Updated documentation."
msgstr ""
"Deze release voegt een nieuwe, veel meer versimpelde interface toe om "
"tekstattributen te configureren. \n"
"Documentatie bijgewerkt. "
